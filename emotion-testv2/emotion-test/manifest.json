{
  "manifest_version": 3,
  "name": "AI Attention Tutor",
  "version": "1.0.0",
  "description": "Monitors your attention and emotions locally using AI.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "action": {
    "default_title": "Launch AI Tutor"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}